{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "dror-plugins-official",
  "description": "Directory of popular Claude Code extensions including development tools, productivity plugins, and MCP integrations",
  "owner": {
    "name": "dror",
    "email": "support@anthropic.com"
  },
  "plugins": [
    
    {
      "name": "basedpyright-lsp",
      "description": "Python language server using basedpyright - a pyright fork with stricter type checking and additional rules",
      "version": "1.0.0",
      "author": {
        "name": "Tyler Laprade"
      },
      "source": "./external_plugins/basedpyright",
      "category": "development",
      "strict": false,
      "homepage": "https://github.com/DetachHead/basedpyright",
      "tags": ["community-managed"],
      "lspServers": {
        "basedpyright": {
          "command": "basedpyright-langserver",
          "args": ["--stdio"],
          "extensionToLanguage": {
            ".py": "python",
            ".pyi": "python"
          }
        }
      }
    }
  ]
}
